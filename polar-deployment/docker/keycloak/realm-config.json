{
  "realm": "PolarBookshop",
  "enabled": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "customer",
        "description": "Customer role for Polar Bookshop"
      },
      {
        "name": "employee",
        "description": "Employee role for Polar Bookshop"
      }
    ]
  },
  "clients": [
    {
      "clientId": "edge-service",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "polar-keycloak-secret",
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:9000/login/oauth2/code/*",
        "http://localhost:9000"
      ],
      "webOrigins": [
        "http://localhost:9000"
      ],
      "publicClient": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "bjorn",
      "enabled": true,
      "firstName": "Bjorn",
      "lastName": "Vinterberg",
      "email": "bjorn@example.com",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "requiredActions": [],
      "realmRoles": [ "customer" ]
    },
    {
      "username": "isabelle",
      "enabled": true,
      "firstName": "Isabelle",
      "lastName": "Dahl",
      "email": "isabelle@example.com",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "requiredActions": [],
      "realmRoles": [ "customer", "employee" ]
    }
  ]
}